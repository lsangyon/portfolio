	POP	GR1	; if	comp
	CPA	GR1, GR2	; if	comp
	JPL	TRUE3	; if	comp	comp-op
	LD	GR1, =#0000	; if	comp	comp-op
	JUMP	BOTH3	; if	comp	comp-op
TRUE3	NOP		; if	comp	comp-op
	LD	GR1, =#FFFF	; if	comp	comp-op
BOTH3	NOP		; if	comp	comp-op
