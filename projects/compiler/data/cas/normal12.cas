	LD	GR1, VAR, GR2	; if	multiple	left
	PUSH	0, GR1	; if	multiple	left
	POP	GR2	; if	multiple
	POP	GR1	; if	multiple
	CALL	MULT	; if	multiple
	PUSH	0, GR2	; if	multiple
	POP	GR2	; if	minus
	LD	GR1, =0	; if	minus
	SUBA	GR1, GR2	; if	minus
	PUSH	0, GR1	; if	minus
